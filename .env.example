# Copy to `.env` for local dev, and set these as runtime env vars on the VPS (PM2).
# NEVER commit the real .env.

# --- Email (quote/contact form) via SMTP2GO HTTP API ---
# API key from https://app.smtp2go.com (Settings → API Keys); starts with "api-"
SMTP2GO_API_KEY=api-XXXXXXXXXXXXXXXX
# Where enquiries are delivered:
CONTACT_TO=info@surreycontracting.co.uk
# From address — the sender domain must be verified in SMTP2GO:
CONTACT_FROM=Surrey Contracting Website <website@surreycontracting.co.uk>

# --- Sanity (case studies / projects CMS) ---
# projectId + dataset are public (safe to expose in the client build).
PUBLIC_SANITY_PROJECT_ID=mhqgpyb9
PUBLIC_SANITY_DATASET=production
