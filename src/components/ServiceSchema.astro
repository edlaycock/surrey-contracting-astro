---
interface Props {
  name: string;
  slug: string;
  description: string;
}
const { name, slug, description } = Astro.props;
const site = 'https://surreycontracting.co.uk';

const service = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name,
  serviceType: name,
  description,
  url: `${site}/${slug}`,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Surrey Contracting Limited',
    url: site,
    telephone: '01932 932650',
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Surrey, London & the South East',
  },
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${site}/services` },
    { '@type': 'ListItem', position: 3, name, item: `${site}/${slug}` },
  ],
};
---
<script type="application/ld+json" set:html={JSON.stringify(service)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
