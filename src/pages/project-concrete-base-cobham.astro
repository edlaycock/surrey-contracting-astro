---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Concrete Base Installation — Premier Inn Cobham · Project — Surrey Contracting Limited"
  description="Emergency concrete base installation for the Premier Inn in Cobham — completed within 3 days of initial site visit by Surrey Contracting Limited."
  path="/project-concrete-base-cobham"
  ogTitle="Concrete Base Installation — Premier Inn Cobham — Surrey Contracting Limited"
  active="projects"
>

<section class="proj-hero">
  <div class="page-hero-bg" aria-hidden="true">
    <div class="page-hero-img" style="background-image:url('/assets/img/projects/concrete-base-cobham.jpg')"></div>
    <div class="page-hero-vignette"></div>
  </div>
  <div class="container proj-hero-inner">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/index">Home</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <a href="/projects">Projects</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <span>Concrete Base Installation — Premier Inn Cobham</span>
    </nav>
    <span class="proj-hero-tag">Commercial · Groundworks</span>
    <h1 class="page-title">Concrete Base Installation — Premier Inn Cobham</h1>
    <p class="page-lede">Emergency concrete base installation for the Premier Inn in Cobham — completed within 3 days of initial site visit.</p>
  </div>
</section>

<section class="page-section">
  <div class="container proj-detail-grid">
    <aside class="proj-meta-card">
      <h4>Project info</h4>
      <dl class="proj-meta-list">
        <div><dt>Client</dt><dd>Premier Inn</dd></div>
        <div><dt>Location</dt><dd>Cobham, Surrey</dd></div>
        <div><dt>Sector</dt><dd>Commercial</dd></div>
        <div><dt>Services</dt><dd>Groundworks</dd></div>
        <div><dt>Year</dt><dd>2023</dd></div>
        <div><dt>Status</dt><dd><span class="proj-status">Completed</span></dd></div>
      </dl>
      <a href="/contact" class="btn btn-yellow btn-block">Discuss a similar project →</a>
    </aside>

    <div class="proj-body">
      <h2>The project</h2>
      <p>Surrey Contracting carried out a concrete base installation for a new water tank at the Premier Inn, Cobham. We excavated the area and installed new base works and 150mm of reinforced concrete.</p>
      <p>This was carried out as a matter of urgency as their contractor let them down last minute. We carried out and completed the works within 3 days of the initial site visit.</p>
    </div>
  </div>
</section>

<section class="page-section page-section-grey">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">On site</span>
      <h2 class="section-title">In progress &amp; on completion.</h2>
    </div>
    <div class="proj-gallery">
      <div class="proj-thumb proj-thumb-lg" style="background-image:url('/assets/img/projects/concrete-base-cobham-2.jpg')"></div>
      <div class="proj-thumb" style="background-image:url('/assets/img/projects/concrete-base-cobham-3.jpg')"></div>
      <div class="proj-thumb" style="background-image:url('/assets/img/projects/concrete-base-cobham-4.jpg')"></div>
    </div>
  </div>
</section>

<section class="page-section">
  <div class="container">
    <div class="section-head split">
      <div>
        <span class="eyebrow">More projects</span>
        <h2 class="section-title">See another case study.</h2>
      </div>
      <a href="/projects" class="btn btn-outline-dark">All projects →</a>
    </div>
    <div class="gallery-grid">
      <article class="gallery-card">
        <a href="/project-tarmac-repairs-sutton" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/tarmac-repairs-sutton.jpg')"><span class="gallery-tag">Surfacing</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Commercial · Sutton, London</span>
            <h3>Tarmac Repairs — Sutton High School</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
      <article class="gallery-card">
        <a href="/project-site-clearance-earthworks" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/site-clearance-earthworks.jpg')"><span class="gallery-tag">Earthworks</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Residential · Farnham, Surrey</span>
            <h3>Site Clearance and Earthworks</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
      <article class="gallery-card">
        <a href="/project-domestic-earthworks" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/domestic-earthworks.jpg')"><span class="gallery-tag">Earthworks</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Residential · Horsell, Woking</span>
            <h3>Domestic Earthworks Project</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
    </div>
  </div>
</section>
</BaseLayout>
