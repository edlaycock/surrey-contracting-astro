---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Tarmac Driveway · Project — Surrey Contracting Limited"
  description="New tarmac driveway with brick retaining wall and drainage for a residential client in West Humble, Dorking — Surrey Contracting Limited."
  path="/project-tarmac-driveway"
  ogTitle="Tarmac Driveway — Surrey Contracting Limited"
  active="projects"
>

<section class="proj-hero">
  <div class="page-hero-bg" aria-hidden="true">
    <div class="page-hero-img" style="background-image:url('/assets/img/projects/tarmac-driveway.jpg')"></div>
    <div class="page-hero-vignette"></div>
  </div>
  <div class="container proj-hero-inner">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/index">Home</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <a href="/projects">Projects</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <span>Tarmac Driveway</span>
    </nav>
    <span class="proj-hero-tag">Residential · Surfacing</span>
    <h1 class="page-title">Tarmac Driveway</h1>
    <p class="page-lede">New tarmac driveway with brick retaining wall and drainage for a residential client in West Humble, Dorking.</p>
  </div>
</section>

<section class="page-section">
  <div class="container proj-detail-grid">
    <aside class="proj-meta-card">
      <h4>Project info</h4>
      <dl class="proj-meta-list">
        <div><dt>Client</dt><dd>Private residential</dd></div>
        <div><dt>Location</dt><dd>West Humble, Dorking</dd></div>
        <div><dt>Sector</dt><dd>Residential</dd></div>
        <div><dt>Services</dt><dd>Tarmac · Drainage</dd></div>
        <div><dt>Year</dt><dd>2023</dd></div>
        <div><dt>Status</dt><dd><span class="proj-status">Completed</span></dd></div>
      </dl>
      <a href="/contact" class="btn btn-yellow btn-block">Discuss a similar project →</a>
    </aside>

    <div class="proj-body">
      <h2>The project</h2>
      <p>We installed a new tarmac driveway for a residential client in West Humble, Dorking as well as new brick retaining wall and drainage including a soakaway. The driveway was edged with silver grey granite setts and the tarmac was installed and finished with a white spar speckle stone.</p>
    </div>
  </div>
</section>

<section class="page-section page-section-grey">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">On site</span>
      <h2 class="section-title">In progress &amp; on completion.</h2>
    </div>
    <div class="proj-gallery">
      <div class="proj-thumb proj-thumb-lg" style="background-image:url('/assets/img/projects/tarmac-driveway-2.jpg')"></div>
      <div class="proj-thumb" style="background-image:url('/assets/img/projects/tarmac-driveway-3.jpg')"></div>
      <div class="proj-thumb" style="background-image:url('/assets/img/projects/tarmac-driveway-4.jpg')"></div>
    </div>
  </div>
</section>

<section class="page-section">
  <div class="container">
    <div class="section-head split">
      <div>
        <span class="eyebrow">More projects</span>
        <h2 class="section-title">See another case study.</h2>
      </div>
      <a href="/projects" class="btn btn-outline-dark">All projects →</a>
    </div>
    <div class="gallery-grid">
      <article class="gallery-card">
        <a href="/project-tarmac-driveway-fetcham" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/tarmac-driveway-fetcham.jpg')"><span class="gallery-tag">Surfacing</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Residential · Fetcham, Surrey</span>
            <h3>Tarmac Driveway, Fetcham, Surrey</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
      <article class="gallery-card">
        <a href="/project-tarmac-repairs-sutton" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/tarmac-repairs-sutton.jpg')"><span class="gallery-tag">Surfacing</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Commercial · Sutton, London</span>
            <h3>Tarmac Repairs — Sutton High School</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
      <article class="gallery-card">
        <a href="/project-drainage-ascot" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/drainage-ascot.jpg')"><span class="gallery-tag">Drainage</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Residential · Ascot, Surrey</span>
            <h3>Drainage Installation — Ascot</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
    </div>
  </div>
</section>
</BaseLayout>
