---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceSchema from '../components/ServiceSchema.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is bulk earthworks and what does it involve?",
      "acceptedAnswer": { "@type": "Answer", "text": "Bulk earthworks, often called cut and fill, involves the excavation, movement and placement of large volumes of soil, stone or rock to prepare land for construction. Surrey Contracting delivers bulk excavation, site levelling, topsoil management, ground remediation and muck-away for residential and commercial projects across Surrey, London and the South East." }
    },
    {
      "@type": "Question",
      "name": "Does Surrey Contracting carry out cut and fill on development sites?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Surrey Contracting delivers cut and fill earthworks for residential developments, commercial plots and private residential sites, working to approved drawings, site levels and programme requirements." }
    },
    {
      "@type": "Question",
      "name": "Can Surrey Contracting handle muck-away and waste disposal?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Surrey Contracting manages surplus materials including excavated soil and demolition arisings, ensuring responsible disposal and recycling in line with current environmental and safety regulations. On-site concrete crushing is also available to reduce haulage and landfill costs." }
    },
    {
      "@type": "Question",
      "name": "What plant does Surrey Contracting use for bulk earthworks?",
      "acceptedAnswer": { "@type": "Answer", "text": "Surrey Contracting operates a fleet of excavators and dumpers suitable for any scale of earthworks, from small domestic projects requiring 1.5-tonne mini diggers through to large commercial schemes requiring 30-tonne machines. All operators are fully trained, qualified and insured." }
    },
    {
      "@type": "Question",
      "name": "What areas does Surrey Contracting cover for bulk earthworks?",
      "acceptedAnswer": { "@type": "Answer", "text": "Surrey Contracting covers Surrey, London and the South East for bulk earthworks, operating from its base between Cobham and Leatherhead. Areas include Guildford, Woking, Esher, Epsom, Weybridge, Reigate, Dorking, Kingston and the wider M25 corridor." }
    }
  ]
};
---
<BaseLayout
  title="Bulk Earthworks | Surrey Contracting Limited"
  description="Specialist Bulk Earthworks, Site Levelling &amp; Land Remediation Services"
  path="/earthworks"
  active="services"
>
  <ServiceSchema slot="head" name="Bulk Earthworks" slug="earthworks" description="Bulk earthworks and excavation across Surrey, large-scale excavation, site levelling, land clearance and land remediation." />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

<section class="page-hero">
  <div class="page-hero-bg" aria-hidden="true">
    <div class="page-hero-img" style="background-image:url('/assets/img/bulk-earthworks.jpg')"></div>
    <div class="page-hero-vignette"></div>
  </div>
  <div class="container page-hero-inner">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <a href="/services">Services</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <span>Bulk Earthworks</span>
    </nav>
    <h1 class="page-title">Bulk Earthworks &amp; Excavation Contractors Across Surrey &amp; London</h1>
    <p class="page-lede">Specialist Bulk Earthworks, Site Levelling &amp; Land Remediation Services</p>
  </div>
</section>

<section class="page-section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Bulk Earthworks</span>
      <h2 class="section-title">Residential and commercial earthmoving, expertly delivered.</h2>
      <p class="section-lede">Surrey Contracting is an experienced earthworks and excavation contractor operating across Surrey, London and the South East.We deliver bulk excavation, cut and fill, site levelling and ground preparation works for residential and commercial projects. Using modern plant, skilled operators and a practical approach to site logistics, we help prepare construction sites safely, efficiently and ready for the next phase of works.Whether your project requires localised excavation, full level reduction, or a complete cut and fill package, Surrey Contracting provides a reliable Bulk earthworks solutions for projects of varying size and complexity.</p>
    </div>
  </div>
</section>

<section class="svc-detail">
  <div class="container svc-detail-grid">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/bulk-earthworks.jpg')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Bulk Earthworks</h2>
      <p class="lede-dark">Bulk earthworks, often referred to as cut and fill, involve the excavation, movement and placement of large volumes of soil, stone or rock to prepare land for construction.Surrey Contracting delivers bulk earthworks and excavation services across Surrey, London and the South East. Working with modern plant and experienced operators, we prepare sites safely and efficiently for residential developments, commercial projects and larger construction schemes.Our team works to approved drawings, site levels and programme requirements, ensuring surplus materials are managed, recycled or disposed of responsibly in line with current environmental and safety regulations.Whether preparing a new-build development, commercial plot or private residential site, Surrey Contracting provides reliable earthworks solutions with a clear focus on accuracy, efficiency and professional project delivery.</p>
      <ul class="feature-list">
        <li>Cut &amp; fill</li>
        <li>Topsoil management &amp; stockpiling</li>
        <li>Ground remediation</li>
        <li>Environmental compliance</li>
        <li>Waste recycling &amp; disposal</li>
      </ul>
    </div>
  </div>
</section>

<section class="svc-detail svc-detail-alt">
  <div class="container svc-detail-grid svc-detail-reverse">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/services/earthworks-excavations.jpg')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Lakes, Ponds &amp; Swimming Pools</h2>
      <p class="lede-dark">We specialise in bulk excavation works. Whether it's for a new swimming pool or adjustments to an existing lake or pond, we can provide a complete solution from start to finish. We have a fleet of excavators and dumpers that can handle any scale of excavation, from small domestic gardens to large multi-phase developments, and our skilled operators perform the work safely, accurately and on schedule.</p>
      <ul class="feature-list">
        <li>Large-scale excavation</li>
        <li>Multi-phase developments</li>
        <li>Fleet of excavators &amp; dumpers</li>
        <li>Accurate level control</li>
        <li>Aggregate supply</li>
      </ul>
    </div>
  </div>
</section>

<section class="svc-detail">
  <div class="container svc-detail-grid">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/services/earthworks-clearance.jpg')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Land Clearance</h2>
      <p class="lede-dark">Surrey Contracting provides professional land clearance services for commercial, residential development and construction sites across Surrey, London and the South East.From removing vegetation, debris, waste materials and redundant structures to prepare the area for the next stage of works. Our highly experienced team can manage land clearance projects of varying sizes, from smaller enabling works through to larger development sites.</p>
      <ul class="feature-list">
        <li>Structure removal</li>
        <li>Vegetation clearance</li>
        <li>Waste segregation</li>
        <li>Domestic &amp; commercial</li>
        <li>Responsible disposal</li>
      </ul>
    </div>
  </div>
</section>

<section class="svc-detail svc-detail-alt">
  <div class="container svc-detail-grid svc-detail-reverse">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/services/earthworks-levelling.jpg')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Land &amp; Site Levelling</h2>
      <p class="lede-dark">We provide high-quality land levelling services, the process of flattening or adjusting existing slopes and undulations to create a level surface. Land levelling is often required for construction, landscaping or agricultural purposes, to improve the performance and appearance of the land. We use advanced surveying and engineering methods to ensure accuracy and precision. Surrey Contracting has the expertise and equipment to carry out land levelling for any type of project, from garden re-grading to large development platforms.</p>
      <ul class="feature-list">
        <li>Slope adjustment</li>
        <li>Development platforms</li>
        <li>Garden re-grading</li>
        <li>Surveying &amp; engineering</li>
        <li>Agricultural levelling</li>
      </ul>
    </div>
  </div>
</section>

<section class="page-section page-section-grey">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Common questions</span>
      <h2 class="section-title">Bulk Earthworks FAQs</h2>
    </div>
    <div class="faq-list">
      <details class="faq-item">
        <summary>What is bulk earthworks and what does it involve?</summary>
        <p>Bulk earthworks, often called cut and fill, involves the excavation, movement and placement of large volumes of soil, stone or rock to prepare land for construction. Surrey Contracting delivers bulk excavation, site levelling, topsoil management, ground remediation and muck-away for residential and commercial projects across Surrey, London and the South East.</p>
      </details>
      <details class="faq-item">
        <summary>Does Surrey Contracting carry out cut and fill on development sites?</summary>
        <p>Yes. Surrey Contracting delivers cut and fill earthworks for residential developments, commercial plots and private residential sites, working to approved drawings, site levels and programme requirements.</p>
      </details>
      <details class="faq-item">
        <summary>Can Surrey Contracting handle muck-away and waste disposal?</summary>
        <p>Yes. Surrey Contracting manages surplus materials including excavated soil and demolition arisings, ensuring responsible disposal and recycling in line with current environmental and safety regulations. On-site concrete crushing is also available to reduce haulage and landfill costs.</p>
      </details>
      <details class="faq-item">
        <summary>What plant does Surrey Contracting use for bulk earthworks?</summary>
        <p>Surrey Contracting operates a fleet of excavators and dumpers suitable for any scale of earthworks, from small domestic projects requiring 1.5-tonne mini diggers through to large commercial schemes requiring 30-tonne machines. All operators are fully trained, qualified and insured.</p>
      </details>
      <details class="faq-item">
        <summary>What areas does Surrey Contracting cover for bulk earthworks?</summary>
        <p>Surrey Contracting covers Surrey, London and the South East for bulk earthworks, operating from its base between Cobham and Leatherhead. Areas include Guildford, Woking, Esher, Epsom, Weybridge, Reigate, Dorking, Kingston and the wider M25 corridor.</p>
      </details>
    </div>
  </div>
</section>

<section class="cta-strip">
  <div class="container cta-strip-row">
    <div>
      <h3>Got an earthworks project to discuss?</h3>
    </div>
    <div class="cta-strip-ctas">
      <a href="/contact" class="btn btn-yellow">Request a quote</a>
      <a href="tel:01932932650" class="btn btn-ghost-light">01932 932650</a>
    </div>
  </div>
</section>
</BaseLayout>
