---
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Surrey Contracting Limited",
  "url": "https://surreycontracting.co.uk",
  "telephone": "01932 932650",
  "email": "info@surreycontracting.co.uk",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Upper Leewood Farm Yard, Effingham Common Road",
    "addressLocality": "Leatherhead",
    "postalCode": "KT24 5JQ",
    "addressCountry": "GB"
  },
  "description": "Professional groundworks, bulk earthworks, commercial surfacing and residential driveways across Surrey.",
  "areaServed": {
    "@type": "GeoCircle",
    "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 51.296, "longitude": -0.331 },
    "geoRadius": "40000"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Demolition", "url": "https://surreycontracting.co.uk/demolition" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Groundworks", "url": "https://surreycontracting.co.uk/groundworks" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Bulk Earthworks", "url": "https://surreycontracting.co.uk/earthworks" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Commercial Surfacing", "url": "https://surreycontracting.co.uk/surfacing" } }
    ]
  },
  "description": "Demolition, groundworks, bulk earthworks and commercial surfacing contractor based in Leatherhead, Surrey. Serving residential, commercial and developer clients across Surrey, London and the South East.",
  "logo": "https://surreycontracting.co.uk/assets/img/logo.svg",
  "addressRegion": "Surrey",
  "areaServed": [
    { "@type": "Place", "name": "Surrey" },
    { "@type": "Place", "name": "London" },
    { "@type": "Place", "name": "Cobham" },
    { "@type": "Place", "name": "Leatherhead" },
    { "@type": "Place", "name": "Guildford" },
    { "@type": "Place", "name": "Esher" },
    { "@type": "Place", "name": "Woking" },
    { "@type": "Place", "name": "Reigate" },
    { "@type": "Place", "name": "Epsom" },
    { "@type": "Place", "name": "Weybridge" },
    { "@type": "Place", "name": "Kingston upon Thames" }
  ],
  "sameAs": ["https://www.linkedin.com/company/surrey-contracting/"]
};
---
<BaseLayout
  title="Surrey Contracting Limited | Groundworks, Surfacing & Civils across Surrey"
  description="Groundworks, bulk earthworks and commercial surfacing across Surrey, London and the South East. Surrey Contracting Limited has 15+ years on site and self-delivers every job."
  ogTitle="Surrey Contracting Limited | Groundworks, Surfacing & Civils across Surrey"
  path="/"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

<!-- ============ HERO ============ -->
<section class="hero" id="top">
  <div class="hero-bg" id="heroBg" aria-hidden="true">
    <div class="hero-img hero-img-1"></div>
    <div class="hero-img hero-img-2"></div>
    <div class="hero-vignette" style="opacity: 0.5"></div>
  </div>

  <div class="container hero-inner">
    <div class="hero-slides">
      <article class="hero-slide is-active" data-slide="0">
        <div class="hero-eyebrow">
          <span class="dot"></span>
          Established across Surrey &amp; London
        </div>
        <h1 class="hero-title">
          Built on Experience.<br>
          <span class="hero-accent">Driven by Quality.</span>
        </h1>
        <p class="hero-sub">
          Demolition, groundworks, bulk earthworks and commercial surfacing across Surrey, London and the South East. One team, 15+ years on site, and work that's right first time.
        </p>
        <div class="hero-ctas">
          <a href="#quote" class="btn btn-yellow">Request a quote</a>
          <a href="#services" class="btn btn-ghost-light">Our services →</a>
        </div>
      </article>

      <article class="hero-slide" data-slide="1">
        <div class="hero-eyebrow">
          <span class="dot"></span>
          One contractor, every discipline
        </div>
        <h1 class="hero-title">
          A
          <span class="word-rotator" aria-label="Demolition, Groundworks, Bulk Earthworks, Commercial Surfacing">
            <span class="word-track" id="wordTrack">
              <span class="word">Demolition</span>
              <span class="word">Groundworks</span>
              <span class="word">Bulk Earthworks</span>
              <span class="word">Commercial Surfacing</span>
              <span class="word">Demolition</span>
            </span>
          </span><br>
          <span class="hero-tail">contractor for any site.</span>
        </h1>
        <p class="hero-sub">
          From enabling works and site clearance through to completed surfacing and external works, one experienced team delivering across commercial, residential and developer projects throughout Surrey.
        </p>
        <div class="hero-ctas">
          <a href="#quote" class="btn btn-yellow">Request a quote</a>
          <a href="#services" class="btn btn-ghost-light">Our services →</a>
        </div>
      </article>
    </div>

    <div class="hero-trust">
      <div class="trust-item"><strong>15+</strong><span>years of experience</span></div>
      <div class="trust-divider"></div>
      <div class="trust-item"><strong>Surrey</strong><span>&amp; the South East</span></div>
      <div class="trust-divider"></div>
      <div class="trust-item"><strong>CHAS</strong><span>accredited</span></div>
      <div class="trust-divider"></div>
      <div class="trust-item"><strong>5★</strong><span>client rating</span></div>
    </div>

    <div class="hero-dots" id="heroDots" aria-label="Hero slide selector">
      <button class="dot-btn is-active" data-go="0" aria-label="Slide 1"></button>
      <button class="dot-btn" data-go="1" aria-label="Slide 2"></button>
    </div>
  </div>

  <a href="#services" class="hero-scroll" aria-label="Scroll to services">
    <span>Scroll</span>
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
  </a>
</section>

<!-- ============ AI ANSWER BLOCK ============ -->
<section class="intro-answer" aria-label="About Surrey Contracting">
  <div class="container">
    <p><strong>Surrey Contracting Limited</strong> is a demolition, groundworks, bulk earthworks and commercial surfacing contractor based in Leatherhead, Surrey. The company delivers enabling works, site clearance, drainage, foundations, excavation, tarmac surfacing and external works for residential, commercial and developer clients. Surrey Contracting is CHAS accredited, SafeContractor approved and SSIP certified, and operates across Surrey, London and the South East — including Cobham, Guildford, Woking, Epsom, Weybridge, Reigate and Kingston upon Thames.</p>
  </div>
</section>

<!-- ============ SERVICE TILES ============ -->
<section class="services" id="services">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">What we do</span>
      <h2 class="section-title">A Demolition, Groundworks, Earthworks &amp; Surfacing contractor for any site.</h2>
      <p class="section-lede">Four core disciplines, delivered in-house by our specialist team. We take your project from its initial stages right through to the finished surface, with no chain of subbies and different contracts to chase, just one point of contact for complete simplicity.</p>
    </div>

    <div class="svc-grid">
      <a href="/demolition" class="svc-card" style="background-image:url(/assets/img/demolition.jpg)">
        <div class="svc-overlay"></div>
        <div class="svc-meta">
          <h3>Demolition</h3>
          <p>Commercial and residential demolition, from small residential projects to large commercial sites: soft strip-outs, on-site crushing and asbestos removal.</p>
          <span class="svc-arrow">Explore service →</span>
        </div>
      </a>

      <a href="/groundworks" class="svc-card" style="background-image:url(/assets/img/groundworks.webp)">
        <div class="svc-overlay"></div>
        <div class="svc-meta">
          <h3>Groundworks</h3>
          <p>Foundations, foul and surface-water drainage, concrete works and infrastructure works for residential and commercial developments.</p>
          <span class="svc-arrow">Explore service →</span>
        </div>
      </a>

      <a href="/earthworks" class="svc-card" style="background-image:url(/assets/img/bulk-earthworks.jpg)">
        <div class="svc-overlay"></div>
        <div class="svc-meta">
          <h3>Bulk Earthworks</h3>
          <p>From small-scale residential site levelling through to large-scale commercial sites, we specialise in bulk earthworks, excavations and site levelling.</p>
          <span class="svc-arrow">Explore service →</span>
        </div>
      </a>

      <a href="/surfacing" class="svc-card" style="background-image:url(/assets/img/surfacing.jpg)">
        <div class="svc-overlay"></div>
        <div class="svc-meta">
          <h3>Commercial Surfacing</h3>
          <p>Complete commercial surfacing, from schools to car parks, industrial yards and access roads, in tarmac, resin-bound, block paving and paving.</p>
          <span class="svc-arrow">Explore service →</span>
        </div>
      </a>
    </div>

  </div>
</section>

<!-- ============ VALUE PROP STRIP ============ -->
<section class="values">
  <div class="container values-grid">
    <div class="value">
      <div class="value-ico">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <h4>Accredited &amp; insured</h4>
      <p>CHAS, Constructionline, SafeContractor and £10m PLI. Audited every job.</p>
    </div>
    <div class="value">
      <div class="value-ico">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12l3 3 6-6 6 6 3-3"/><path d="M3 18l3 3 6-6 6 6 3-3"/></svg>
      </div>
      <h4>One point of contact</h4>
      <p>No call centres. No multiple points of contact. One direct line every time, right from the start of your project through to handover.</p>
    </div>
    <div class="value">
      <div class="value-ico">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
      </div>
      <h4>Logistics, Programmes &amp; Planning</h4>
      <p>From the planning stage through to site programmes and logistics, we plan every stage from start to finish.</p>
    </div>
    <div class="value">
      <div class="value-ico">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16v12H5.5L4 18z"/><path d="M8 9h8M8 12h5"/></svg>
      </div>
      <h4>Talk to a contracts manager</h4>
      <p>Not a call-centre. A site lead on the phone, every time, from quote to defects.</p>
    </div>
  </div>
</section>

<!-- ============ ABOUT / INTRO ============ -->
<section class="about" id="about">
  <div class="container about-grid">
    <div class="about-copy">
      <span class="eyebrow eyebrow-yellow">About Surrey Contracting</span>
      <h2 class="section-title light">Built on Experience. Driven by Quality.</h2>
      <p class="lede">Surrey Contracting Limited is a site enabling, demolition, groundworks, earthworks and surfacing contractor based near Leatherhead, working across Surrey, London and the South East.</p>
      <p>We have been successfully delivering residential and commercial external works projects for over 15 years, providing turnkey solutions for developers, main contractors, homeowners, self-builders, local businesses and established organisations. No project is too small or too large. Every project receives the same level of expertise, care and professional service from start to finish.</p>
      <p>We manage every stage of the project in-house, from site clearance through to the finished surface. With our experienced team and structured approach, you can be confident your project will be delivered on time, to a high standard, and with quality maintained right through to handover.</p>

      <ul class="bullet-list">
        <li><span>15+ years of experience across Surrey, London &amp; the South East</span></li>
        <li><span>Self-delivery of site enabling works, groundworks, earthworks &amp; surfacing</span></li>
        <li><span>Turnkey solutions for projects of all sizes and complexities, providing reliable services for residential, commercial and contractor-led works.</span></li>
        <li><span>Reliable workmanship, audit-grade paperwork</span></li>
      </ul>

      <div class="about-ctas">
        <a href="#projects" class="btn btn-yellow">See recent projects</a>
        <a href="/about" class="btn btn-outline-dark">About Us</a>
      </div>
    </div>

    <div class="about-visual">
      <div class="about-photo about-photo-1" style="background-image:url('/assets/img/brickwork.jpeg')">
        <div class="ph-label">Foundations · Surrey</div>
      </div>
      <div class="about-photo about-photo-2" style="background-image:url('/assets/img/bulk-earthworks.jpg')">
        <div class="ph-label">Bulk earthworks</div>
      </div>
      <div class="about-badge">
        <div class="bg-num">15+</div>
        <div class="bg-lbl">Years delivering<br>projects across<br>Surrey &amp; London</div>
      </div>
    </div>
  </div>
</section>

<!-- ============ FEATURED SERVICE (alt) ============ -->
<section class="feature feature-dark">
  <div class="container feature-grid">
    <div class="feature-media">
      <div class="feature-photo" style="background-image:url('/assets/img/surfacing.jpg')">
      </div>
      <div class="feature-tag">Commercial surfacing</div>
    </div>
    <div class="feature-copy">
      <span class="eyebrow eyebrow-yellow">Commercial Surfacing</span>
      <h2 class="section-title light">Hard-wearing surfacing for commercial sites.</h2>
      <p>Surfacing for car parks, private roads, industrial estates, access routes and hardstanding. We lay tarmac and asphalt (base, binder and surface course) over a properly prepared sub-base, because the finish is only ever as good as what's underneath.</p>
      <div class="feature-stats">
        <div><strong>Car parks</strong><span>&amp; access roads</span></div>
        <div><strong>Tarmac</strong><span>&amp; asphalt</span></div>
        <div><strong>Industrial</strong><span>estates &amp; yards</span></div>
      </div>
      <a href="/surfacing" class="btn btn-yellow">Explore commercial surfacing →</a>
    </div>
  </div>
</section>

<!-- ============ PROCESS ============ -->
<section class="process">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">How we work</span>
      <h2 class="section-title">A four-step delivery you can plan to.</h2>
    </div>
    <ol class="process-row">
      <li>
        <div class="proc-num">01</div>
        <h4>Initial site visit and measure</h4>
        <p>Free measured visit within 5 working days. Levels, access, services and constraints captured.</p>
      </li>
      <li>
        <div class="proc-num">02</div>
        <h4>Fixed-price quote</h4>
        <p>Itemised proposal, materials, plant, prelims, programme. No surprises later in the project.</p>
      </li>
      <li>
        <div class="proc-num">03</div>
        <h4>Mobilise &amp; deliver</h4>
        <p>RAMS issued, plant booked, team allocated. Weekly progress reports straight to your inbox.</p>
      </li>
      <li>
        <div class="proc-num">04</div>
        <h4>Sign-off and project handover</h4>
        <p>Snag-walk, O&amp;M pack handed over and a 12-month defects window we actually return for.</p>
      </li>
    </ol>
  </div>
</section>

<!-- ============ STATS BAND ============ -->
<section class="stats">
  <div class="container stats-row">
    <div class="stat">
      <div class="stat-num">100s</div>
      <div class="stat-lbl">Projects delivered</div>
    </div>
    <div class="stat">
      <div class="stat-num" data-target="15" data-suffix="+">0</div>
      <div class="stat-lbl">Years of experience</div>
    </div>
    <div class="stat">
      <div class="stat-num" data-target="90" data-suffix="%">0</div>
      <div class="stat-lbl">Repeat-client rate</div>
    </div>
    <div class="stat">
      <div class="stat-num" data-target="100" data-suffix="%">0</div>
      <div class="stat-lbl">Surrey-based team</div>
    </div>
  </div>
</section>

<!-- ============ PROJECTS GALLERY ============ -->
<section class="projects" id="projects">
  <div class="container">
    <div class="section-head split">
      <div>
        <span class="eyebrow">Recent work</span>
        <h2 class="section-title">Projects from across the county.</h2>
      </div>
      <a href="/projects" class="btn btn-outline-dark">View full gallery →</a>
    </div>

    <div class="proj-grid">
      <article class="proj proj-lg">
        <div class="proj-photo" style="background-image:url('/assets/img/bulk-earthworks.jpg')"></div>
        <div class="proj-meta">
          <span class="proj-tag">Bulk Earthworks</span>
          <h3>Commercial site cut &amp; fill</h3>
          <p>Large-scale excavation and site levelling using modern tracked plant for a phased commercial development.</p>
        </div>
      </article>

      <article class="proj">
        <div class="proj-photo" style="background-image:url('/assets/img/hard-landscaping.jpg')"></div>
        <div class="proj-meta">
          <span class="proj-tag">Hard Landscaping</span>
          <h3>Porcelain patio &amp; gabion</h3>
          <p>Large-format porcelain laid over a SUDS-friendly base with bespoke gabion retaining wall.</p>
        </div>
      </article>

      <article class="proj">
        <div class="proj-photo" style="background-image:url('/assets/img/groundworks.webp')"></div>
        <div class="proj-meta">
          <span class="proj-tag">Groundworks</span>
          <h3>Surface-water drainage</h3>
          <p>Excavation, twin-wall pipework and reinstatement for a private estate drainage scheme.</p>
        </div>
      </article>

      <article class="proj">
        <div class="proj-photo" style="background-image:url('/assets/img/surfacing.jpg')"></div>
        <div class="proj-meta">
          <span class="proj-tag">Surfacing</span>
          <h3>Kerbing &amp; access road</h3>
          <p>Precast kerbing and tarmac access road for a commercial yard, delivered over two phased weekends.</p>
        </div>
      </article>

      <article class="proj">
        <div class="proj-photo" style="background-image:url('/assets/img/block-paving.jpeg')"></div>
        <div class="proj-meta">
          <span class="proj-tag">Block Paving</span>
          <h3>Block-paved driveway</h3>
          <p>Bespoke residential block paving with edge restraints and full base preparation.</p>
        </div>
      </article>

      <article class="proj">
        <div class="proj-photo" style="background-image:url('/assets/img/brickwork.jpeg')"></div>
        <div class="proj-meta">
          <span class="proj-tag">Groundworks</span>
          <h3>Substructure &amp; foundations</h3>
          <p>Strip foundations, drainage and oversite to a residential extension scheme, taken from site clearance to slab.</p>
        </div>
      </article>
    </div>
  </div>
</section>

<!-- ============ AREAS WE COVER ============ -->
<section class="areas" id="areas">
  <div class="container areas-grid">
    <div class="areas-copy">
      <span class="eyebrow eyebrow-yellow">Areas we cover</span>
      <h2 class="section-title light">Local roots with a nationwide reach.</h2>
      <p>Our HQ is based just between Cobham and Leatherhead, but we operate across Surrey, London and the South East. If you're inside the M25 ring or along the A3 corridor, we're a short call out.</p>
      <ul class="areas-list">
        <li>Cobham</li><li>Leatherhead</li><li>Guildford</li><li>Esher</li>
        <li>Woking</li><li>Reigate</li><li>Dorking</li><li>Epsom</li>
        <li>Weybridge</li><li>Kingston</li><li>Redhill</li><li>Surbiton</li>
      </ul>
    </div>
    <div class="areas-map" aria-hidden="true">
      <div class="map-frame">
        <img src="/assets/img/coverage-map.png" alt="Surrey Contracting coverage area covering Surrey and surrounding regions including Guildford, Woking, Cobham, Leatherhead, Epsom, Kingston upon Thames, Walton-on-Thames, Weybridge, Godalming and Cranleigh." class="map-img">
        <div class="map-pin" aria-hidden="true">
          <span class="pin-dot"></span>
          <span class="pin-ring"></span>
          <span class="pin-label">HQ · Leatherhead</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ TESTIMONIAL ============ -->
<section class="testimonial">
  <div class="container">
    <svg class="quote-mark" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M7 7h4v4H7c0 4 2 6 4 6v3c-5 0-8-3-8-9V7zm10 0h4v4h-4c0 4 2 6 4 6v3c-5 0-8-3-8-9V7z"/></svg>
    <div class="t-slider" id="tSlider">
      <div class="t-track" id="tTrack">
        <article class="t-card">
          <blockquote>
            Surrey Contracting picked up a job another firm had walked away from. They re-priced honestly, hit every milestone and handed over a paperwork pack that sailed through our auditor. They're our first call for anything below 600mm.
          </blockquote>
          <div class="t-attrib">
            <div class="t-avatar">JM</div>
            <div>
              <strong>James M.</strong>
              <span>Senior PM · Tier-1 housebuilder</span>
            </div>
          </div>
        </article>
        <article class="t-card">
          <blockquote>
            We needed our main car park resurfaced inside a six-week summer window with zero slippage. They hit the date with two days to spare and the finish has held up beautifully through two winters of school-run traffic.
          </blockquote>
          <div class="t-attrib">
            <div class="t-avatar">SK</div>
            <div>
              <strong>Sarah K.</strong>
              <span>Estates Manager · Independent school, Surrey</span>
            </div>
          </div>
        </article>
        <article class="t-card">
          <blockquote>
            Quoted on the Monday, mobilised the following week, finished in three days and tidied up properly before they left. The drive looks better than I'd dared hope, and the price was exactly what they said it would be.
          </blockquote>
          <div class="t-attrib">
            <div class="t-avatar">MT</div>
            <div>
              <strong>Mark T.</strong>
              <span>Homeowner · Cobham</span>
            </div>
          </div>
        </article>
        <article class="t-card">
          <blockquote>
            Site clearance and bulk earthworks on a constrained urban plot, they handled the muck-away, the levels and the neighbour management without us having to chase a thing. Genuine, capable contractors.
          </blockquote>
          <div class="t-attrib">
            <div class="t-avatar">DR</div>
            <div>
              <strong>David R.</strong>
              <span>Contracts Manager · Commercial developer</span>
            </div>
          </div>
        </article>
      </div>
    </div>
    <div class="t-dots" id="tDots" role="tablist" aria-label="Testimonials">
      <button type="button" class="is-active" aria-label="Show testimonial 1"></button>
      <button type="button" aria-label="Show testimonial 2"></button>
      <button type="button" aria-label="Show testimonial 3"></button>
      <button type="button" aria-label="Show testimonial 4"></button>
    </div>
  </div>
</section>

<!-- ============ QUOTE FORM ============ -->
<section class="quote" id="quote">
  <div class="container quote-grid">
    <div class="quote-copy">
      <span class="eyebrow eyebrow-yellow">Get in touch</span>
      <h2 class="section-title light">Request a quote.</h2>
      <p>Tell us about your site and we'll be back inside one working day with a measured site-visit date.</p>
      <div class="quote-direct">
        <div>
          <span class="qd-lbl">Call us</span>
          <a href="tel:01932932650" class="qd-val">01932 932650</a>
        </div>
        <div>
          <span class="qd-lbl">Yard</span>
          <span class="qd-val">Upper Leewood Farm Yard, Effingham Common Road, Leatherhead, KT24 5JQ</span>
        </div>
      </div>
    </div>

    <form class="quote-form" id="quoteForm" novalidate>
      <div style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;" aria-hidden="true">
        <label>Company website<input type="text" name="_honeypot" tabindex="-1" autocomplete="off"></label>
      </div>
      <div class="qf-row">
        <label>
          <span>Name</span>
          <input required name="name" type="text" placeholder="Your full name">
        </label>
        <label>
          <span>Phone</span>
          <input required name="phone" type="tel" placeholder="01932 932650">
        </label>
      </div>
      <label>
        <span>Email</span>
        <input required name="email" type="email" placeholder="you@email.com">
      </label>
      <fieldset class="qf-checks">
        <legend>What do you need?</legend>
        <label class="check"><input type="checkbox" name="svc" value="Demolition"><span>Demolition</span></label>
        <label class="check"><input type="checkbox" name="svc" value="Groundworks"><span>Groundworks</span></label>
        <label class="check"><input type="checkbox" name="svc" value="Bulk Earthworks"><span>Bulk Earthworks</span></label>
        <label class="check"><input type="checkbox" name="svc" value="Commercial Surfacing"><span>Commercial Surfacing</span></label>
        <label class="check"><input type="checkbox" name="svc" value="Other"><span>Other</span></label>
      </fieldset>
      <label>
        <span>Project postcode</span>
        <input name="postcode" type="text" placeholder="GU1 1AA">
      </label>
      <label>
        <span>Tell us about the job</span>
        <textarea name="message" rows="4" placeholder="Site type, scale, target start date…"></textarea>
      </label>
      <label class="qf-hear">
        <span>Where did you hear about us?</span>
        <select name="source">
          <option>Google</option>
          <option>Referral / client</option>
          <option>LinkedIn</option>
          <option>Site signage</option>
          <option>Other</option>
        </select>
      </label>
      <button type="submit" class="btn btn-yellow btn-block">Send enquiry</button>
      <p class="qf-success" id="qfSuccess" hidden>Thanks, we've got it. A contracts manager will be in touch within one working day.</p>
    </form>
  </div>
</section>

