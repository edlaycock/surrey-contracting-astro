---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceSchema from '../components/ServiceSchema.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What demolition services does Surrey Contracting offer?",
      "acceptedAnswer": { "@type": "Answer", "text": "Surrey Contracting provides full structural demolition, partial demolition for renovation, soft strip-out, site clearance, concrete crushing, site hoarding and security, and licensed asbestos removal for residential and commercial clients across Surrey, London and the South East." }
    },
    {
      "@type": "Question",
      "name": "Does Surrey Contracting carry out asbestos removal before demolition?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Surrey Contracting carries out fully licensed and insured asbestos removal prior to soft strip or structural demolition works, in accordance with current HSE requirements. Services include asbestos surveys, sampling, licensed ACM removal, encapsulation, and certified waste disposal." }
    },
    {
      "@type": "Question",
      "name": "Do you provide site hoarding for demolition projects?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Surrey Contracting installs surface-mounted and dug-in hoarding, Harris fencing, vehicle and pedestrian gates, and works with specialist partners to provide site alarm systems and CCTV monitoring." }
    },
    {
      "@type": "Question",
      "name": "Are Surrey Contracting's demolition operatives qualified?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. All operatives hold CSCS and CCDO qualifications. Surrey Contracting produces full risk assessments and method statements for every demolition project and holds CHAS, SafeContractor and SSIP accreditation." }
    },
    {
      "@type": "Question",
      "name": "What areas does Surrey Contracting cover for demolition?",
      "acceptedAnswer": { "@type": "Answer", "text": "Surrey Contracting covers Surrey, London and the South East, operating from its base between Cobham and Leatherhead. Areas served include Guildford, Woking, Esher, Epsom, Weybridge, Reigate, Dorking, Kingston and the wider M25 corridor." }
    }
  ]
};
---
<BaseLayout
  title="Demolition Services | Surrey Contracting Limited"
  description="Commercial and residential demolition services across Surrey, site clearance, soft strip, concrete crushing and site hoarding."
  path="/demolition"
  active="services"
>
  <ServiceSchema slot="head" name="Demolition" slug="demolition" description="Commercial and residential demolition services across Surrey, site clearance, soft strip, concrete crushing and site hoarding." />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

<section class="page-hero">
  <div class="page-hero-bg" aria-hidden="true">
    <div class="page-hero-img" style="background-image:url('/assets/img/demolition.jpg')"></div>
    <div class="page-hero-vignette"></div>
  </div>
  <div class="container page-hero-inner">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <a href="/services">Services</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <span>Demolition</span>
    </nav>
    <h1 class="page-title">Demolition Services</h1>
    <p class="page-lede">Commercial and residential demolition services across Surrey, London and the South East.</p>
  </div>
</section>

<section class="page-section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Demolition</span>
      <h2 class="section-title">Comprehensive demolition services, safely delivered.</h2>
      <p class="section-lede">Surrey Contracting delivers comprehensive demolition services to commercial and residential clients across Surrey, London and the South East. Our highly experienced team ensures every project is meticulously planned and executed with safety and precision. From initial site surveys through to final clearance, we manage every stage of the demolition process, committed to safety, quality and customer satisfaction.</p>
    </div>
  </div>
</section>

<section class="svc-detail">
  <div class="container svc-detail-grid">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/demolition.jpg')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Complete Residential &amp; Commercial Site Demolition</h2>
      <p class="lede-dark">Surrey Contracting boasts years of experience delivering extensive demolition services to commercial and self-build residential clients. Our highly skilled demolition operatives have extensive experience across projects of varying sizes and complexities, positioning us as a reliable partner for any demolition requirement. Whether it's a complete structural demolition, partial demolition for renovation, or selective demolition to preserve specific elements, our team delivers safely and efficiently. We carry out full risk assessments and method statements for every project, and our operatives hold all necessary CSCS and CPCS qualifications.</p>
      <ul class="feature-list">
        <li>Full structural demolition</li>
        <li>Partial demolition for renovation</li>
        <li>Residential and Commercial demolition undertaken</li>
        <li>Risk assessments &amp; method statements</li>
        <li>CSCS &amp; CCDO qualified operatives</li>
      </ul>
    </div>
  </div>
</section>

<section class="svc-detail svc-detail-alt">
  <div class="container svc-detail-grid svc-detail-reverse">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/services/demolition-clearance.webp')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Site Clearance</h2>
      <p class="lede-dark">Site clearance is an essential step from the completion of demolition through to site preparation for the next phase of construction. Surrey Contracting offers cost-effective site clearance solutions to prepare your land for subsequent project stages. We remove all debris, vegetation, redundant structures and waste materials, leaving your site clean and ready for development. Our team works efficiently to minimise programme delays, and we ensure all waste is disposed of responsibly in accordance with current environmental regulations. Our team brings a wealth of knowledge and experience to ensure your project is completed on schedule and on budget.</p>
      <ul class="feature-list">
        <li>Post-demolition clearance</li>
        <li>Vegetation &amp; tree removal</li>
        <li>Redundant structure removal</li>
        <li>Waste segregation &amp; disposal</li>
        <li>Environmental compliance</li>
      </ul>
    </div>
  </div>
</section>

<section class="svc-detail">
  <div class="container svc-detail-grid">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/services/demolition-softstrip.webp')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Complete Soft Strip-Out Solutions</h2>
      <p class="lede-dark">Our soft strip demolition service focuses on removing all non-structural elements from a building, including fixtures, fittings, suspended ceilings, partition walls, mechanical and electrical installations, floor coverings and decorative finishes, while maintaining the structural framework throughout. This is often the first phase of a refurbishment or fit-out project, and requires careful planning to avoid damage to the retained structure. Our operatives are experienced in working within occupied buildings and live environments where noise, dust and disruption must be carefully managed.</p>
      <ul class="feature-list">
        <li>Fixtures &amp; fittings removal</li>
        <li>Suspended ceiling strip</li>
        <li>M&amp;E removal</li>
        <li>Floor covering removal</li>
        <li>Working in occupied buildings</li>
      </ul>
    </div>
  </div>
</section>

<section class="svc-detail svc-detail-alt">
  <div class="container svc-detail-grid svc-detail-reverse">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/services/demolition-crushing.jpg')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Concrete Crushing</h2>
      <p class="lede-dark">Concrete crushing provides an efficient and sustainable way to process demolition arisings into reusable aggregate, reducing landfill, haulage movements and overall project costs.Surrey Contracting offers concrete crushing solutions for commercial, industrial and development sites, with options for on-site mobile crushing or off-site processing depending on project scale, site access and programme requirements.Where suitable, on-site crushing can reduce muck-away costs and limit the need to import new aggregates. Processed material can then be reused as sub-base, general fill or drainage aggregate, supporting a more cost-effective and environmentally responsible approach to site preparation.</p>
      <ul class="feature-list">
        <li>Onsite mobile crushing</li>
        <li>Offsite processing</li>
        <li>Aggregate recycling</li>
        <li>Sub-base production</li>
        <li>Reduced landfill &amp; transport costs</li>
      </ul>
    </div>
  </div>
</section>

<section class="svc-detail">
  <div class="container svc-detail-grid">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/services/demolition-hoarding.webp')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Site Hoarding &amp; Security</h2>
      <p class="lede-dark">Securing your site is critical before any demolition or construction work begins. Surrey Contracting provides a full range of site hoarding and security solutions including surface-mounted hoarding, dug-in hoarding, temporary Harris fencing, and vehicle and pedestrian gates. We also work with specialist partners to provide site alarm systems and CCTV monitoring for added security during the project duration. All hoarding is installed to meet health and safety requirements and can be branded with your company signage if required.</p>
      <ul class="feature-list">
        <li>Surface-mounted hoarding</li>
        <li>Dug-in hoarding</li>
        <li>Harris fencing</li>
        <li>Vehicle &amp; pedestrian gates</li>
        <li>CCTV &amp; alarm partnerships</li>
      </ul>
    </div>
  </div>
</section>

<section class="svc-detail svc-detail-alt">
  <div class="container svc-detail-grid svc-detail-reverse">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/Asbestos.jpg')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Licensed Asbestos Removal</h2>
      <p class="lede-dark">Prior to any soft strip or structural demolition works, asbestos-containing materials must be identified, managed and removed in accordance with current HSE requirements.Surrey Contracting carrys out fully licensed and fully insured asbestos removal. This ensures the site is made safe, compliant and ready for the next phase of works, while protecting operatives, site users and the public, and helping to maintain the overall project programme.</p>
      <ul class="feature-list">
        <li>Asbestos surveys &amp; sampling</li>
        <li>Licensed ACM removal</li>
        <li>Encapsulation &amp; make-safe</li>
        <li>Certified waste disposal</li>
        <li>HSE-compliant working</li>
      </ul>
    </div>
  </div>
</section>

<section class="page-section page-section-grey">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Common questions</span>
      <h2 class="section-title">Demolition FAQs</h2>
    </div>
    <div class="faq-list">
      <details class="faq-item">
        <summary>What demolition services does Surrey Contracting offer?</summary>
        <p>Surrey Contracting provides full structural demolition, partial demolition for renovation, soft strip-out, site clearance, concrete crushing, site hoarding and security, and licensed asbestos removal for residential and commercial clients across Surrey, London and the South East.</p>
      </details>
      <details class="faq-item">
        <summary>Does Surrey Contracting carry out asbestos removal before demolition?</summary>
        <p>Yes. Surrey Contracting carries out fully licensed and insured asbestos removal prior to soft strip or structural demolition works, in accordance with current HSE requirements. Services include asbestos surveys, sampling, licensed ACM removal, encapsulation and certified waste disposal.</p>
      </details>
      <details class="faq-item">
        <summary>Do you provide site hoarding for demolition projects?</summary>
        <p>Yes. Surrey Contracting installs surface-mounted and dug-in hoarding, Harris fencing, vehicle and pedestrian gates, and works with specialist partners to provide site alarm systems and CCTV monitoring.</p>
      </details>
      <details class="faq-item">
        <summary>Are Surrey Contracting's demolition operatives qualified?</summary>
        <p>Yes. All operatives hold CSCS and CCDO qualifications. Surrey Contracting produces full risk assessments and method statements for every demolition project and holds CHAS, SafeContractor and SSIP accreditation.</p>
      </details>
      <details class="faq-item">
        <summary>What areas does Surrey Contracting cover for demolition?</summary>
        <p>Surrey Contracting covers Surrey, London and the South East, operating from its base between Cobham and Leatherhead. Areas served include Guildford, Woking, Esher, Epsom, Weybridge, Reigate, Dorking, Kingston and the wider M25 corridor.</p>
      </details>
    </div>
  </div>
</section>

<section class="cta-strip">
  <div class="container cta-strip-row">
    <div>
      <h3>Got a demolition project to discuss?</h3>
    </div>
    <div class="cta-strip-ctas">
      <a href="/contact" class="btn btn-yellow">Request a quote</a>
      <a href="tel:01932932650" class="btn btn-ghost-light">01932 932650</a>
    </div>
  </div>
</section>
</BaseLayout>
