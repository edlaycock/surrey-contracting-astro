---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjects, urlFor } from '../lib/sanity';

const projects = await getProjects();
const categories = [...new Set(projects.flatMap((p) => p.categories ?? []))].sort();
---
<BaseLayout
  title="Our Projects | Surrey Contracting Limited"
  description="Recent groundworks, earthworks and surfacing projects delivered across Surrey, commercial, residential and public sector."
  path="/projects"
  ogTitle="Projects | Surrey Contracting Limited"
  active="projects"
>

<section class="page-hero">
  <div class="page-hero-bg" aria-hidden="true">
    <div class="page-hero-img" style="background-image:url('/assets/img/bulk-earthworks.jpg')"></div>
    <div class="page-hero-vignette"></div>
  </div>
  <div class="container page-hero-inner">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <span>Projects</span>
    </nav>
    <h1 class="page-title">Our Projects</h1>
    <p class="page-lede">A cross-section of recent work across Surrey and the Home Counties, commercial, residential, public-sector and everything in between.</p>
  </div>
</section>

<section class="page-section">
  <div class="container">
    <div class="section-head split">
      <div>
        <span class="eyebrow">Recent work</span>
        <h2 class="section-title">Projects from across the county.</h2>
      </div>
      <a href="/contact" class="btn btn-outline-dark">Discuss a project →</a>
    </div>

    <div class="filter-bar">
      <div class="filter-group">
        <span class="filter-label">Category</span>
        <button class="chip is-active" data-filter="cat" data-value="All">All</button>
        {categories.map((cat) => (
          <button class="chip" data-filter="cat" data-value={cat}>{cat}</button>
        ))}
      </div>
    </div>

    <div class="gallery-grid" id="galleryGrid">
      {projects.map((p) => (
        <article class="gallery-card" data-cats={(p.categories ?? []).join(',')}>
          <a href={`/projects/${p.slug}`} class="gallery-link">
            <div
              class="gallery-photo"
              style={`background-image:url('${p.heroImage ? urlFor(p.heroImage).width(700).height(500).fit('crop').url() : ''}')`}
            >
              {p.categories?.[0] && <span class="gallery-tag">{p.categories[0]}</span>}
            </div>
            <div class="gallery-body">
              <span class="gallery-meta">{[...(p.categories ?? []), p.location].filter(Boolean).join(' · ')}</span>
              <h3>{p.title}</h3>
              <span class="gallery-cta">View project →</span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="cta-strip">
  <div class="container cta-strip-row">
    <div>
      <h3>Want to be the next case study?</h3>
      <p style="color: rgb(209, 209, 209); font-size: 16px">Free measured visit, itemised quote, then we get on with the job.</p>
    </div>
    <div class="cta-strip-ctas">
      <a href="/contact" class="btn btn-yellow" style="background-color: rgb(60, 60, 60); color: rgb(255, 255, 255)">Request a quote</a>
      <a href="tel:01932932650" class="btn btn-ghost-light">01932 932650</a>
    </div>
  </div>
</section>

</BaseLayout>
