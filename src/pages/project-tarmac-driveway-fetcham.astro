---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Tarmac Driveway, Fetcham, Surrey · Project — Surrey Contracting Limited"
  description="100sqm tarmac driveway installation with base course and SMA wearing course in Fetcham, Surrey — Surrey Contracting Limited."
  path="/project-tarmac-driveway-fetcham"
  ogTitle="Tarmac Driveway, Fetcham, Surrey — Surrey Contracting Limited"
  active="projects"
>

<section class="proj-hero">
  <div class="page-hero-bg" aria-hidden="true">
    <div class="page-hero-img" style="background-image:url('/assets/img/projects/tarmac-driveway-fetcham.jpg')"></div>
    <div class="page-hero-vignette"></div>
  </div>
  <div class="container proj-hero-inner">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/index">Home</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <a href="/projects">Projects</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <span>Tarmac Driveway, Fetcham, Surrey</span>
    </nav>
    <span class="proj-hero-tag">Residential · Surfacing</span>
    <h1 class="page-title">Tarmac Driveway, Fetcham, Surrey</h1>
    <p class="page-lede">100sqm tarmac driveway installation with base course and SMA wearing course in Fetcham, Surrey.</p>
  </div>
</section>

<section class="page-section">
  <div class="container proj-detail-grid">
    <aside class="proj-meta-card">
      <h4>Project info</h4>
      <dl class="proj-meta-list">
        <div><dt>Client</dt><dd>Private residential</dd></div>
        <div><dt>Location</dt><dd>Fetcham, Surrey</dd></div>
        <div><dt>Sector</dt><dd>Residential</dd></div>
        <div><dt>Services</dt><dd>Surfacing</dd></div>
        <div><dt>Year</dt><dd>2023</dd></div>
        <div><dt>Status</dt><dd><span class="proj-status">Completed</span></dd></div>
      </dl>
      <a href="/contact" class="btn btn-yellow btn-block">Discuss a similar project →</a>
    </aside>

    <div class="proj-body">
      <h2>The project</h2>
      <p>100sqm area — supply and lay 50mm of 20mm base course macadam to an area prepared by us. Supply and lay 30mm of 6mm SMA wearing course macadam.</p>
    </div>
  </div>
</section>

<section class="page-section page-section-grey">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">On site</span>
      <h2 class="section-title">In progress &amp; on completion.</h2>
    </div>
    <div class="proj-gallery">
      <div class="proj-thumb proj-thumb-lg" style="background-image:url('/assets/img/projects/tarmac-driveway-fetcham-2.jpg')"></div>
      <div class="proj-thumb" style="background-image:url('/assets/img/projects/tarmac-driveway-fetcham-3.jpg')"></div>
      <div class="proj-thumb" style="background-image:url('/assets/img/projects/tarmac-driveway-fetcham-4.jpg')"></div>
    </div>
  </div>
</section>

<section class="page-section">
  <div class="container">
    <div class="section-head split">
      <div>
        <span class="eyebrow">More projects</span>
        <h2 class="section-title">See another case study.</h2>
      </div>
      <a href="/projects" class="btn btn-outline-dark">All projects →</a>
    </div>
    <div class="gallery-grid">
      <article class="gallery-card">
        <a href="/project-tarmac-driveway" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/tarmac-driveway.jpg')"><span class="gallery-tag">Surfacing</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Residential · West Humble, Dorking</span>
            <h3>Tarmac Driveway</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
      <article class="gallery-card">
        <a href="/project-site-clearance-earthworks" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/site-clearance-earthworks.jpg')"><span class="gallery-tag">Earthworks</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Residential · Farnham, Surrey</span>
            <h3>Site Clearance and Earthworks</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
      <article class="gallery-card">
        <a href="/project-complete-landscape" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/complete-landscape.jpg')"><span class="gallery-tag">Hard Landscaping</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Residential · Virginia Water, Surrey</span>
            <h3>Complete Re-landscape</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
    </div>
  </div>
</section>
</BaseLayout>
