---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Tarmac Repairs — Sutton High School · Project — Surrey Contracting Limited"
  description="Emergency tarmac footpath repairs at Sutton High School, completed over a weekend to minimise disruption — Surrey Contracting Limited."
  path="/project-tarmac-repairs-sutton"
  ogTitle="Tarmac Repairs — Sutton High School — Surrey Contracting Limited"
  active="projects"
>

<section class="proj-hero">
  <div class="page-hero-bg" aria-hidden="true">
    <div class="page-hero-img" style="background-image:url('/assets/img/projects/tarmac-repairs-sutton.jpg')"></div>
    <div class="page-hero-vignette"></div>
  </div>
  <div class="container proj-hero-inner">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/index">Home</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <a href="/projects">Projects</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <span>Tarmac Repairs — Sutton High School</span>
    </nav>
    <span class="proj-hero-tag">Commercial · Surfacing</span>
    <h1 class="page-title">Tarmac Repairs — Sutton High School</h1>
    <p class="page-lede">Emergency tarmac footpath repairs at Sutton High School, completed over a weekend to minimise disruption.</p>
  </div>
</section>

<section class="page-section">
  <div class="container proj-detail-grid">
    <aside class="proj-meta-card">
      <h4>Project info</h4>
      <dl class="proj-meta-list">
        <div><dt>Client</dt><dd>Sutton High School</dd></div>
        <div><dt>Location</dt><dd>Sutton, London</dd></div>
        <div><dt>Sector</dt><dd>Education</dd></div>
        <div><dt>Services</dt><dd>Surfacing</dd></div>
        <div><dt>Year</dt><dd>2023</dd></div>
        <div><dt>Status</dt><dd><span class="proj-status">Completed</span></dd></div>
      </dl>
      <a href="/contact" class="btn btn-yellow btn-block">Discuss a similar project →</a>
    </aside>

    <div class="proj-body">
      <h2>The project</h2>
      <p>Surrey Contracting carried out emergency repairs at Sutton High School after extensive building works. We were called in at very short notice to carry out and complete minor repairs to the footpaths throughout the school prior to the students starting the following week. All repairs were carried out over the weekend to minimise disruption to the school. 6mm SMA and Buff ULTI Colour were used on this project to match the existing surfaces.</p>
    </div>
  </div>
</section>

<section class="page-section page-section-grey">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">On site</span>
      <h2 class="section-title">In progress &amp; on completion.</h2>
    </div>
    <div class="proj-gallery">
      <div class="proj-thumb proj-thumb-lg" style="background-image:url('/assets/img/projects/tarmac-repairs-sutton-2.jpg')"></div>
      <div class="proj-thumb" style="background-image:url('/assets/img/projects/tarmac-repairs-sutton-3.jpg')"></div>
      <div class="proj-thumb" style="background-image:url('/assets/img/projects/tarmac-repairs-sutton-4.jpg')"></div>
    </div>
  </div>
</section>

<section class="page-section">
  <div class="container">
    <div class="section-head split">
      <div>
        <span class="eyebrow">More projects</span>
        <h2 class="section-title">See another case study.</h2>
      </div>
      <a href="/projects" class="btn btn-outline-dark">All projects →</a>
    </div>
    <div class="gallery-grid">
      <article class="gallery-card">
        <a href="/project-tarmac-driveway" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/tarmac-driveway.jpg')"><span class="gallery-tag">Surfacing</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Residential · West Humble, Dorking</span>
            <h3>Tarmac Driveway</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
      <article class="gallery-card">
        <a href="/project-concrete-base-cobham" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/concrete-base-cobham.jpg')"><span class="gallery-tag">Groundworks</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Commercial · Cobham, Surrey</span>
            <h3>Concrete Base Installation — Premier Inn Cobham</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
      <article class="gallery-card">
        <a href="/project-landscape-guildford" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/landscape-guildford.jpg')"><span class="gallery-tag">Hard Landscaping</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Residential · Guildford, Surrey</span>
            <h3>Residential Re-landscape, Guildford, Surrey</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
    </div>
  </div>
</section>
</BaseLayout>
