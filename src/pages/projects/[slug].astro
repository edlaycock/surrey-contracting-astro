---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjects, getProject, urlFor } from '../../lib/sanity';
import { toHTML } from '@portabletext/to-html';

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = await getProject(slug!);
if (!project) return Astro.redirect('/projects');

const allProjects = await getProjects();

const hero = project.heroImage
  ? urlFor(project.heroImage).width(1600).height(900).fit('crop').url()
  : '/assets/img/groundworks.webp';
const bodyHtml = project.body ? toHTML(project.body as never) : '';
const gallery = (project.gallery ?? []).map((g) => ({
  src: urlFor(g.asset).width(900).height(700).fit('crop').url(),
  caption: g.caption,
}));

const heroTag = [project.sector, project.categories?.[0]].filter(Boolean).join(' · ');

const related = allProjects.filter((p) => p.slug !== project.slug).slice(0, 3);

const projectSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": project.title,
  "name": project.title,
  "description": project.summary ?? undefined,
  "url": `https://surreycontracting.co.uk/projects/${project.slug}`,
  "mainEntityOfPage": `https://surreycontracting.co.uk/projects/${project.slug}`,
  "image": hero.startsWith('http') ? hero : `https://surreycontracting.co.uk${hero}`,
  ...(project.location ? { "contentLocation": { "@type": "Place", "name": project.location } } : {}),
  ...(project.year ? { "datePublished": project.year } : {}),
  ...(project.sector ? { "articleSection": project.sector } : {}),
  ...(project.services ? { "about": project.services.split(',').map((service) => ({ "@type": "Thing", "name": service.trim() })) } : {}),
  "author": {
    "@type": "LocalBusiness",
    "name": "Surrey Contracting Limited",
    "url": "https://surreycontracting.co.uk",
    "telephone": "01932 932650",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Upper Leewood Farm Yard, Effingham Common Road",
      "addressLocality": "Leatherhead",
      "addressRegion": "Surrey",
      "postalCode": "KT24 5JQ",
      "addressCountry": "GB"
    }
  },
  "publisher": {
    "@type": "LocalBusiness",
    "name": "Surrey Contracting Limited",
    "url": "https://surreycontracting.co.uk",
    "logo": {
      "@type": "ImageObject",
      "url": "https://surreycontracting.co.uk/assets/logo-color.png"
    }
  }
};
---
<BaseLayout
  title={`${project.title} | Surrey Contracting Limited`}
  description={project.summary || `${project.title}, a project delivered by Surrey Contracting Limited.`}
  path={`/projects/${project.slug}`}
  ogTitle={`${project.title} | Surrey Contracting Limited`}
  active="projects"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(projectSchema)} />

<section class="proj-hero">
  <div class="page-hero-bg" aria-hidden="true">
    <div class="page-hero-img" style={`background-image:url('${hero}')`}></div>
    <div class="page-hero-vignette"></div>
  </div>
  <div class="container proj-hero-inner">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <a href="/projects">Projects</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <span>{project.title}</span>
    </nav>
    {heroTag && <span class="proj-hero-tag">{heroTag}</span>}
    <h1 class="page-title">{project.title}</h1>
    {project.summary && <p class="page-lede">{project.summary}</p>}
  </div>
</section>

<section class="page-section">
  <div class="container proj-detail-grid">
    <aside class="proj-meta-card">
      <h4>Project info</h4>
      <dl class="proj-meta-list">
        {project.client && <div><dt>Client</dt><dd>{project.client}</dd></div>}
        {project.location && <div><dt>Location</dt><dd>{project.location}</dd></div>}
        {project.sector && <div><dt>Sector</dt><dd>{project.sector}</dd></div>}
        {project.services && <div><dt>Services</dt><dd>{project.services}</dd></div>}
        {project.duration
          ? <div><dt>Duration</dt><dd>{project.duration}</dd></div>
          : project.year && <div><dt>Year</dt><dd>{project.year}</dd></div>}
        {project.status && <div><dt>Status</dt><dd><span class="proj-status">{project.status}</span></dd></div>}
      </dl>
      <a href="/contact" class="btn btn-yellow btn-block">Discuss a similar project →</a>
    </aside>

    <div class="proj-body">
      {bodyHtml && <div class="rich-text" set:html={bodyHtml} />}
    </div>
  </div>
</section>

{gallery.length > 0 && (
  <section class="page-section page-section-grey">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">On site</span>
        <h2 class="section-title">In progress &amp; on completion.</h2>
      </div>
      <div class="proj-gallery">
        {gallery.map((g, i) => (
          <div class={`proj-thumb ${i === 0 ? 'proj-thumb-lg' : ''}`} style={`background-image:url('${g.src}')`}>
            {g.caption && <span class="ph-label">{g.caption}</span>}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

{related.length > 0 && (
  <section class="page-section">
    <div class="container">
      <div class="section-head split">
        <div>
          <span class="eyebrow">More projects</span>
          <h2 class="section-title">See another case study.</h2>
        </div>
        <a href="/projects" class="btn btn-outline-dark">All projects →</a>
      </div>
      <div class="gallery-grid">
        {related.map((p) => (
          <article class="gallery-card">
            <a href={`/projects/${p.slug}`} class="gallery-link">
              <div class="gallery-photo" style={`background-image:url('${p.heroImage ? urlFor(p.heroImage).width(600).height(450).fit('crop').url() : ''}')`}>
                {p.categories?.[0] && <span class="gallery-tag">{p.categories[0]}</span>}
              </div>
              <div class="gallery-body">
                <span class="gallery-meta">{[p.sector, p.location].filter(Boolean).join(' · ')}</span>
                <h3>{p.title}</h3>
                <span class="gallery-cta">View project →</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
)}
</BaseLayout>

<style>
  .proj-detail-meta,
  .proj-meta-list { display: flex; flex-direction: column; gap: 14px; }
  .proj-meta-list div { display: flex; flex-direction: column; gap: 2px; }
  .proj-meta-list dt {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--yellow, #e6a91a);
  }
  .proj-meta-list dd { font-size: 1.05rem; margin: 0; }
  .rich-text :global(p) { margin: 0 0 1.1em; line-height: 1.7; }
  .rich-text :global(h2) { margin: 1.6em 0 0.5em; }
  .rich-text :global(ul) { margin: 0 0 1.1em 1.2em; }
  .proj-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    margin: 36px 0;
  }
  .proj-thumb {
    position: relative;
    aspect-ratio: 4/3;
    background-size: cover;
    background-position: center;
    border-radius: 12px;
  }
  .proj-thumb-lg { grid-column: span 2; aspect-ratio: 16/9; }
  .ph-label {
    position: absolute;
    left: 12px;
    bottom: 12px;
    background: rgba(0,0,0,0.65);
    color: #fff;
    font-size: 0.8rem;
    padding: 4px 10px;
    border-radius: 6px;
  }
</style>
