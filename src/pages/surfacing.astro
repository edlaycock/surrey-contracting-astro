---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceSchema from '../components/ServiceSchema.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What commercial surfacing services does Surrey Contracting offer?",
      "acceptedAnswer": { "@type": "Answer", "text": "Surrey Contracting provides tarmac, resin-bound, block paving and concrete surfaces for car parks, access roads, industrial estates, distribution yards, schools, playgrounds and public spaces. Services also include reinstatement and repair, edging and kerbing, line marking, speed bumps and drainage." }
    },
    {
      "@type": "Question",
      "name": "Can Surrey Contracting resurface car parks and access roads in Surrey?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Surrey Contracting handles new-build car park construction and overlay or resurfacing of existing car parks. The team installs tarmac, resin-bound, block paving and concrete surfaces, along with line marking, speed bumps, bollards and drainage." }
    },
    {
      "@type": "Question",
      "name": "Do you carry out emergency surfacing repairs?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Surrey Contracting's reactive surfacing team carries permanent and temporary repair materials and responds quickly to urgent requirements including utility reinstatement, surface patch repairs and emergency resurfacing." }
    },
    {
      "@type": "Question",
      "name": "Can Surrey Contracting work at weekends or nights to minimise disruption?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Surrey Contracting offers phased delivery, weekend working and night-shift surfacing to minimise disruption to business operations, schools and public spaces." }
    },
    {
      "@type": "Question",
      "name": "What areas does Surrey Contracting cover for commercial surfacing?",
      "acceptedAnswer": { "@type": "Answer", "text": "Surrey Contracting covers Surrey, London and the South East for commercial surfacing, operating from its base between Cobham and Leatherhead. Areas include Guildford, Woking, Esher, Epsom, Weybridge, Reigate, Dorking, Kingston and the wider M25 corridor." }
    }
  ]
};
---
<BaseLayout
  title="Commercial Surfacing | Surrey Contracting Limited"
  description="Specialist commercial surfacing across Surrey, London &amp; South East, residential, commercial, car parks, roadways, schools, industrial estates, reinstatement and kerbing."
  path="/surfacing"
  active="services"
>
  <ServiceSchema slot="head" name="Commercial Surfacing" slug="surfacing" description="Specialist commercial surfacing across Surrey, London &amp; South East, residential, commercial, car parks, roadways, schools, industrial estates, reinstatement and kerbing." />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

<section class="page-hero">
  <div class="page-hero-bg" aria-hidden="true">
    <div class="page-hero-img" style="background-image:url('/assets/img/surfacing.jpg')"></div>
    <div class="page-hero-vignette"></div>
  </div>
  <div class="container page-hero-inner">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <a href="/services">Services</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <span>Commercial Surfacing</span>
    </nav>
    <h1 class="page-title">Commercial Surfacing</h1>
    <p class="page-lede">Specialist commercial surfacing across Surrey, London &amp; South East, residential, commercial, car parks, roadways, schools, industrial estates, reinstatement and kerbing.</p>
  </div>
</section>

<section class="page-section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Commercial Surfacing</span>
      <h2 class="section-title">Durable surfacing solutions for every environment.</h2>
      <p class="section-lede">Surrey Contracting offers specialist commercial surfacing designed to withstand heavy use in commercial and industrial environments. From retail units and offices to warehouses, healthcare facilities, schools and public spaces, our professional surfacing solutions deliver safe, long-lasting, durable and visually appealing surfaces that meet strict industry standards. Whether you require emergency repairs, planned reinstatement works or ongoing commercial maintenance, we deliver reliable, cost-effective surfacing solutions tailored to your site and operational needs.</p>
    </div>
  </div>
</section>

<section class="svc-detail">
  <div class="container svc-detail-grid">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/services/surfacing-hero.jpg')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Commercial Surfacing</h2>
      <p class="lede-dark">Our commercial surfacing services cover the full spectrum of external works for businesses, developers and public-sector clients. We install new tarmac, resin-bound, block paving and concrete surfaces for commercial premises, car parks, access roads, industrial estates and distribution yards. Every project is planned to minimise disruption to your business operations, with phased delivery and weekend working available where needed. We use high-quality materials from trusted suppliers and our experienced laying teams ensure a smooth, durable finish every time.</p>
      <ul class="feature-list">
        <li>Tarmac surfacing</li>
        <li>Resin-bound surfaces</li>
        <li>Block paving</li>
        <li>Concrete surfacing</li>
        <li>Phased, weekend &amp; night working</li>
        <li>High-quality material suppliers</li>
      </ul>
    </div>
  </div>
</section>

<section class="svc-detail svc-detail-alt">
  <div class="container svc-detail-grid svc-detail-reverse">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/services/surfacing-reinstatement.jpg')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Reinstatement &amp; Repair</h2>
      <p class="lede-dark">We provide professional commercial reinstatement and repair surfacing solutions for businesses, contractors and property managers across Surrey, London and the South East. Our services are designed to restore damaged surfaces quickly, safely and to a high standard, minimising disruption while delivering long-lasting results. From utility reinstatement works and surface patch repairs to full commercial resurfacing, our reactive surfacing team specialises in delivering reinstatement works safely, efficiently and on time. We carry permanent and temporary repair materials on our vehicles to respond quickly to urgent requirements.</p>
      <ul class="feature-list">
        <li>Utility reinstatement</li>
        <li>Surface patch repairs</li>
        <li>Full resurfacing</li>
        <li>Emergency response</li>
        <li>Permanent &amp; temporary repairs</li>
      </ul>
    </div>
  </div>
</section>

<section class="svc-detail">
  <div class="container svc-detail-grid">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/CAommercial 2.jpg')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Car Park Surfacing</h2>
      <p class="lede-dark">Car parks endure constant vehicle traffic, heavy use and exposure to the elements. Our tarmac, resin-bound, block paving and concrete surfacing solutions provide excellent long-term durability, keeping car parks functional and visually appealing for years with minimal maintenance. We handle everything from new-build car park construction to overlay and resurfacing of existing car parks. Our team can also install line marking, speed bumps, bollards and drainage to complete the project.</p>
      <ul class="feature-list">
        <li>New-build car parks</li>
        <li>Overlay &amp; resurfacing</li>
        <li>Line marking</li>
        <li>Speed bumps &amp; bollards</li>
        <li>Commercial &amp; Industrial yards</li>
      </ul>
    </div>
  </div>
</section>

<section class="svc-detail svc-detail-alt">
  <div class="container svc-detail-grid svc-detail-reverse">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/services/surfacing-schools.jpg')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Schools, Playgrounds &amp; Public Spaces</h2>
      <p class="lede-dark">Public spaces, schools and playgrounds should be designed and installed to accommodate everyone, providing easy, safe access for pedestrians, cyclists and wheelchair users alike. Our highly skilled team ensures all surfaces are installed smooth and even, preventing trips and falls and providing excellent traction in all weather conditions. By incorporating non-slip properties and permeable surfaces, we ensure our surfaces remain functional and safe throughout the year, reducing maintenance requirements while improving overall usability for the public.</p>
      <ul class="feature-list">
        <li>School playgrounds</li>
        <li>Footpaths</li>
        <li>Permeable surfacing</li>
        <li>Non-slip &amp; SUDs-compliant finishes</li>
        <li>DDA-compliant access</li>
        <li>Low-maintenance surfaces</li>
      </ul>
    </div>
  </div>
</section>

<section class="svc-detail">
  <div class="container svc-detail-grid">
    <div class="svc-detail-media">
      <div class="svc-detail-photo" style="background-image:url('/assets/img/Kerbing.jpg')"></div>
    </div>
    <div class="svc-detail-copy">
      <h2 class="section-title">Edging &amp; Kerbing</h2>
      <p class="lede-dark">Alongside our surfacing solutions we provide professional edging and kerbing options that give your project a neat, tidy and defined finish. We install precast concrete kerbs, granite setts, conservation kerbing and block edging to suit the aesthetic and functional requirements of your project. Proper kerbing provides essential edge restraint for tarmac and block paving surfaces, preventing lateral movement and maintaining the integrity of the surfacing over time.</p>
      <ul class="feature-list">
        <li>Precast concrete kerbs</li>
        <li>Granite setts</li>
        <li>Conservation kerbing</li>
        <li>Block edging</li>
        <li>Edge restraint systems</li>
      </ul>
    </div>
  </div>
</section>

<section class="page-section page-section-grey">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Common questions</span>
      <h2 class="section-title">Commercial Surfacing FAQs</h2>
    </div>
    <div class="faq-list">
      <details class="faq-item">
        <summary>What commercial surfacing services does Surrey Contracting offer?</summary>
        <p>Surrey Contracting provides tarmac, resin-bound, block paving and concrete surfaces for car parks, access roads, industrial estates, distribution yards, schools, playgrounds and public spaces. Services also include reinstatement and repair, edging and kerbing, line marking, speed bumps and drainage.</p>
      </details>
      <details class="faq-item">
        <summary>Can Surrey Contracting resurface car parks and access roads in Surrey?</summary>
        <p>Yes. Surrey Contracting handles new-build car park construction and overlay or resurfacing of existing car parks. The team installs tarmac, resin-bound, block paving and concrete surfaces, along with line marking, speed bumps, bollards and drainage.</p>
      </details>
      <details class="faq-item">
        <summary>Do you carry out emergency surfacing repairs?</summary>
        <p>Yes. Surrey Contracting's reactive surfacing team carries permanent and temporary repair materials and responds quickly to urgent requirements including utility reinstatement, surface patch repairs and emergency resurfacing.</p>
      </details>
      <details class="faq-item">
        <summary>Can Surrey Contracting work at weekends or nights to minimise disruption?</summary>
        <p>Yes. Surrey Contracting offers phased delivery, weekend working and night-shift surfacing to minimise disruption to business operations, schools and public spaces.</p>
      </details>
      <details class="faq-item">
        <summary>What areas does Surrey Contracting cover for commercial surfacing?</summary>
        <p>Surrey Contracting covers Surrey, London and the South East for commercial surfacing, operating from its base between Cobham and Leatherhead. Areas include Guildford, Woking, Esher, Epsom, Weybridge, Reigate, Dorking, Kingston and the wider M25 corridor.</p>
      </details>
    </div>
  </div>
</section>

<section class="cta-strip">
  <div class="container cta-strip-row">
    <div>
      <h3>Got a surfacing project to discuss?</h3>
    </div>
    <div class="cta-strip-ctas">
      <a href="/contact" class="btn btn-yellow">Request a quote</a>
      <a href="tel:01932932650" class="btn btn-ghost-light">01932 932650</a>
    </div>
  </div>
</section>
</BaseLayout>
