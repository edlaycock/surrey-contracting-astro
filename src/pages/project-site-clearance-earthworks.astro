---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Site Clearance and Earthworks · Project | Surrey Contracting Limited"
  description="Large-scale site clearance and earthworks for a domestic client in Farnham, Surrey, 80 tonnes of green waste removed and 100 tonnes of new topsoil brought in."
  path="/project-site-clearance-earthworks"
  ogTitle="Site Clearance and Earthworks | Surrey Contracting Limited"
  active="projects"
>

<section class="proj-hero">
  <div class="page-hero-bg" aria-hidden="true">
    <div class="page-hero-img" style="background-image:url('/assets/img/projects/site-clearance-earthworks.jpg')"></div>
    <div class="page-hero-vignette"></div>
  </div>
  <div class="container proj-hero-inner">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <a href="/projects">Projects</a>
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 6l6 6-6 6"/></svg>
      <span>Site Clearance and Earthworks</span>
    </nav>
    <span class="proj-hero-tag">Residential · Earthworks</span>
    <h1 class="page-title">Site Clearance and Earthworks</h1>
    <p class="page-lede">Large-scale site clearance and earthworks for a domestic client in Farnham, Surrey, 80 tonnes of green waste removed and 100 tonnes of new topsoil brought in.</p>
  </div>
</section>

<section class="page-section">
  <div class="container proj-detail-grid">
    <aside class="proj-meta-card">
      <h4>Project info</h4>
      <dl class="proj-meta-list">
        <div><dt>Client</dt><dd>Private residential</dd></div>
        <div><dt>Location</dt><dd>Farnham, Surrey</dd></div>
        <div><dt>Sector</dt><dd>Residential</dd></div>
        <div><dt>Services</dt><dd>Groundworks · Earthworks</dd></div>
        <div><dt>Year</dt><dd>2023</dd></div>
        <div><dt>Status</dt><dd><span class="proj-status">Completed</span></dd></div>
      </dl>
      <a href="/contact" class="btn btn-yellow btn-block">Discuss a similar project →</a>
    </aside>

    <div class="proj-body">
      <h2>The project</h2>
      <p>The team carried out a project for a domestic client in Farnham, Surrey. We were asked to clear a sizeable section of overgrown land after building works were completed. After our initial site visit, we were more than happy to carry this work out and completely understood our client's vision.</p>
      <p>We now have a section of usable land and garden that the client can enjoy, with a phase 2 planned involving planting, turfing, and some hard landscape works. We removed around 80 tonnes of green waste and reused the soil on site, as well as bringing in around 100 tonnes of new topsoil which we levelled and created new slopes and gradients throughout.</p>
    </div>
  </div>
</section>

<section class="page-section page-section-grey">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">On site</span>
      <h2 class="section-title">In progress &amp; on completion.</h2>
    </div>
    <div class="proj-gallery">
      <div class="proj-thumb proj-thumb-lg" style="background-image:url('/assets/img/projects/site-clearance-earthworks-2.jpg')"></div>
      <div class="proj-thumb" style="background-image:url('/assets/img/projects/site-clearance-earthworks-3.jpg')"></div>
      <div class="proj-thumb" style="background-image:url('/assets/img/projects/site-clearance-earthworks-4.jpg')"></div>
    </div>
  </div>
</section>

<section class="page-section">
  <div class="container">
    <div class="section-head split">
      <div>
        <span class="eyebrow">More projects</span>
        <h2 class="section-title">See another case study.</h2>
      </div>
      <a href="/projects" class="btn btn-outline-dark">All projects →</a>
    </div>
    <div class="gallery-grid">
      <article class="gallery-card">
        <a href="/project-domestic-earthworks" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/domestic-earthworks.jpg')"><span class="gallery-tag">Earthworks</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Residential · Horsell, Woking</span>
            <h3>Domestic Earthworks Project</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
      <article class="gallery-card">
        <a href="/project-drainage-ascot" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/drainage-ascot.jpg')"><span class="gallery-tag">Drainage</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Residential · Ascot, Surrey</span>
            <h3>Drainage Installation, Ascot</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
      <article class="gallery-card">
        <a href="/project-tarmac-driveway" class="gallery-link">
          <div class="gallery-photo" style="background-image:url('/assets/img/projects/tarmac-driveway.jpg')"><span class="gallery-tag">Surfacing</span></div>
          <div class="gallery-body">
            <span class="gallery-meta">Residential · West Humble, Dorking</span>
            <h3>Tarmac Driveway</h3>
            <span class="gallery-cta">View project →</span>
          </div>
        </a>
      </article>
    </div>
  </div>
</section>
</BaseLayout>
