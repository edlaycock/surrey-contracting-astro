---
import UtilityBar from '../components/UtilityBar.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const SITE = 'https://surreycontracting.co.uk';

interface Props {
  title: string;
  description: string;
  /** Path for canonical + og:url, e.g. "/services" (no trailing slash). Home = "/". */
  path?: string;
  ogTitle?: string;
  /** Absolute-from-root image path, e.g. "/assets/img/og.jpg" */
  ogImage?: string;
  /** Active top-level nav key: services | health-safety | sectors | projects | about | contact */
  active?: string;
}

const {
  title,
  description,
  path = '/',
  ogTitle,
  ogImage,
  active,
} = Astro.props;

const canonical = SITE + path;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#E6A91A" />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Surrey Contracting Limited" />
  <meta property="og:locale" content="en_GB" />
  <meta name="description" content={description} />
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  {ogImage && <meta property="og:image" content={SITE + ogImage} />}
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/styles.css" />
  <slot name="head" />
</head>
<body>
  <UtilityBar />
  <Nav active={active} />
  <slot />
  <Footer />
  <script>
    import '../scripts/app.js';
  </script>
</body>
</html>
