---
import UtilityBar from '../components/UtilityBar.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

const SITE = 'https://surreycontracting.co.uk';

interface Props {
  title: string;
  description: string;
  /** Path for canonical + og:url, e.g. "/services" (no trailing slash). Home = "/". */
  path?: string;
  ogTitle?: string;
  /** Absolute-from-root image path, e.g. "/assets/img/og.jpg" */
  ogImage?: string;
  /** Active top-level nav key: services | health-safety | sectors | projects | about | contact */
  active?: string;
}

const {
  title,
  description,
  path = '/',
  ogTitle,
  ogImage,
  active,
} = Astro.props;

const canonical = path === '/' ? SITE : SITE + path;
---
<!doctype html>
<html lang="en">
<head>
  <!-- Google Consent Mode v2 — deny by default until user accepts -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', {
      analytics_storage: 'denied',
      ad_storage: 'denied',
      wait_for_update: 500,
    });
    // Returning visitor: apply stored consent before GA fires
    (function(){
      var s = localStorage.getItem('sc_consent');
      if (s === 'granted' || s === 'denied') {
        gtag('consent', 'update', {
          analytics_storage: s === 'granted' ? 'granted' : 'denied',
          ad_storage: s === 'granted' ? 'granted' : 'denied',
        });
      }
    })();
  </script>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-VNBJHFDZRM"></script>
  <script is:inline>
    gtag('js', new Date());
    gtag('config', 'G-VNBJHFDZRM');
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#E6A91A" />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Surrey Contracting Limited" />
  <meta property="og:locale" content="en_GB" />
  <meta name="description" content={description} />
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  {ogImage && <meta property="og:image" content={SITE + ogImage} />}
  <title>{title}</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="stylesheet" href="/styles.css" />
  <slot name="head" />
</head>
<body>
  <UtilityBar />
  <Nav active={active} />
  <slot />
  <Footer />
  <script>
    import '../scripts/app.js';
  </script>
  <CookieBanner />
  <!-- YourTradeQuotes Enquiry Connector -->
  <script is:inline>
  (function() {
    var API_KEY = 'ytq_live_demo_key_12345';
    var ENDPOINT = 'https://europe-west2-yourtradequotes.cloudfunctions.net/submitEnquiry';
    function extractFields(f) {
      var d = {}, cb = {};
      var els = f.querySelectorAll('input,textarea,select');
      for (var i = 0; i < els.length; i++) {
        var el = els[i], k = (el.name||el.id||'').trim();
        if (!k||el.type==='hidden'||el.type==='submit'||el.type==='button'||el.type==='reset') continue;
        if (el.type==='checkbox') { if (el.checked) cb[k] = cb[k] ? cb[k]+', '+(el.value||k) : (el.value||k); }
        else if (el.type==='radio') { if (el.checked) d[k] = el.value; }
        else d[k] = el.value||'';
      }
      for (var c in cb) d[c] = cb[c];
      return d;
    }
    var existing = document.querySelector('form[data-ytq-form]');
    if (!existing) return;
    existing.addEventListener('submit', function() {
      var p = JSON.stringify(Object.assign(extractFields(existing), {apiKey:API_KEY, source:'Website'}));
      if (navigator.sendBeacon) { navigator.sendBeacon(ENDPOINT, new Blob([p],{type:'application/json'})); }
      else { fetch(ENDPOINT,{method:'POST',headers:{'Content-Type':'application/json'},body:p}); }
    });
  })();
  </script>
</body>
</html>
